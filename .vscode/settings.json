{
  "gopls": {
    "buildFlags": ["-tags=test"]
  },
  "go.testTags": "test",
  "files.exclude": {
    "**/.backup": true,
    "**/.git": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/.backup": true,
    "**/.git": true,
    "**/node_modules": true
  },
